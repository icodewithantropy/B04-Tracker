<!-- Progress Log Tab -->
<div id="Progress" class="tabcontent">
  <h3>Daily Progress Log</h3>
  <p>Record each study session. Data saved in your browser.</p>
  <form onsubmit="addLogEntry(); return false;">
    <label>Date: <input type="date" id="logDate" required></label><br><br>
    <label>Hours Studied: <input type="number" id="logHours" min="0" step="0.5" required></label><br><br>
    <label>Questions Attempted: <input type="number" id="logAttempted" min="0" required></label><br><br>
    <label>Correct: <input type="number" id="logCorrect" min="0" required></label><br><br>
    <label>Wrong: <input type="number" id="logWrong" min="0" required></label><br><br>
    <button class="btn">Add Entry</button>
  </form>
  <button class="btn danger" onclick="clearLog()">Clear All Logs</button>
  <h4>Log History</h4>
  <table id="logTable">
    <tr><th>Date</th><th>Hours</th><th>Attempted</th><th>Correct</th><th>Wrong</th><th>Accuracy</th></tr>
  </table>
  <div id="logStats"></div>
</div>

<script>
// Progress log functions
function renderProgressLog(log) {
  var tableBody = document.querySelector('#logTable tbody');
  if (!tableBody) {
    tableBody = document.createElement('tbody');
    document.getElementById('logTable').appendChild(tableBody);
  }
  tableBody.innerHTML = '';
  var totalCorrect = 0, totalWrong = 0, totalAttempted = 0;
  log.forEach(function(entry) {
    var row = tableBody.insertRow();
    row.insertCell().textContent = entry.date;
    row.insertCell().textContent = entry.hours;
    row.insertCell().textContent = entry.attempted;
    row.insertCell().textContent = entry.correct;
    row.insertCell().textContent = entry.wrong;
    var acc = (entry.attempted > 0) ? ((entry.correct / entry.attempted)*100).toFixed(1) + '%' : 'N/A';
    row.insertCell().textContent = acc;
    totalCorrect += entry.correct;
    totalWrong += entry.wrong;
    totalAttempted += entry.attempted;
  });
  var overallAcc = (totalAttempted > 0) ? ((totalCorrect / totalAttempted)*100).toFixed(1) : 0;
  document.getElementById('logStats').innerHTML = '<p>Total Attempted: ' + totalAttempted + ' | Accuracy: ' + overallAcc + '%</p>';
  // Update progress bar
  document.getElementById('overallProgress').style.width = overallAcc + '%';
  document.getElementById('overallProgress').textContent = overallAcc + '% overall accuracy';
}

function addLogEntry() {
  var date = document.getElementById('logDate').value;
  var hours = document.getElementById('logHours').value;
  var attempted = parseInt(document.getElementById('logAttempted').value);
  var correct = parseInt(document.getElementById('logCorrect').value);
  var wrong = parseInt(document.getElementById('logWrong').value);
  if (!date || isNaN(attempted) || isNaN(correct) || isNaN(wrong)) return;
  var log = loadData('progressLog') || [];
  log.push({date: date, hours: hours, attempted: attempted, correct: correct, wrong: wrong});
  saveData('progressLog', log);
  renderProgressLog(log);
  document.getElementById('logDate').value = '';
  document.getElementById('logHours').value = '';
  document.getElementById('logAttempted').value = '';
  document.getElementById('logCorrect').value = '';
  document.getElementById('logWrong').value = '';
}

function clearLog() {
  if (confirm('Delete all progress logs?')) {
    localStorage.removeItem('progressLog');
    renderProgressLog([]);
    document.getElementById('overallProgress').style.width = '0%';
    document.getElementById('overallProgress').textContent = '0%';
  }
}
</script>
</body>
</html>
