<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JMI B04 Prep Tracker 2026</title>
<style>
  body { font-family: Arial, sans-serif; margin: 20px; background: #f5f5f5; }
  .tab { overflow: hidden; background: #333; border-radius: 10px 10px 0 0; }
  .tab button { background: #333; color: white; float: left; border: none; outline: none; cursor: pointer; padding: 14px 16px; transition: 0.3s; }
  .tab button:hover { background: #555; }
  .tab button.active { background: #4CAF50; }
  .tabcontent { display: none; background: white; padding: 20px; border: 1px solid #ccc; border-top: none; border-radius: 0 0 10px 10px; }
  table { border-collapse: collapse; width: 100%; margin-top: 15px; }
  th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
  th { background-color: #4CAF50; color: white; }
  input[type="text"], input[type="number"], select { padding: 6px; width: 90%; box-sizing: border-box; }
  .btn { background: #4CAF50; color: white; padding: 8px 16px; border: none; cursor: pointer; margin-top: 10px; border-radius: 5px; }
  .btn:hover { background: #45a049; }
  .danger { background: #f44336; }
  .danger:hover { background: #d32f2f; }
  .progress-wrap { background: #eee; border-radius: 20px; margin: 10px 0; }
  .progress-bar { height: 20px; border-radius: 20px; background: #4CAF50; text-align: center; color: white; line-height: 20px; }
</style>
<script>
// Tab functionality
function openTab(evt, tabName) {
  var i, tabcontent, tablinks;
  tabcontent = document.getElementsByClassName("tabcontent");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }
  tablinks = document.getElementsByClassName("tablinks");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].className = tablinks[i].className.replace(" active", "");
  }
  document.getElementById(tabName).style.display = "block";
  evt.currentTarget.className += " active";
}

// Load/save data using localStorage
function saveData(key, value) {
  localStorage.setItem(key, JSON.stringify(value));
}
function loadData(key) {
  return JSON.parse(localStorage.getItem(key));
}

// Initialize checkboxes, dropdowns etc. from saved state
window.onload = function() {
  // open first tab by default
  document.getElementById("Dashboard").style.display = "block";
  document.getElementsByClassName("tablinks")[0].className += " active";

  // load plan checkboxes
  var planState = loadData("planState") || {};
  document.querySelectorAll('#planTable input[type="checkbox"]').forEach(function(cb) {
    cb.checked = planState[cb.id] || false;
    cb.addEventListener('change', function() {
      planState[cb.id] = cb.checked;
      saveData("planState", planState);
    });
  });

  // load topic ratings
  var topicRatings = loadData("topicRatings") || {};
  document.querySelectorAll('#topicTable select').forEach(function(sel) {
    sel.value = topicRatings[sel.id] || "1";
    sel.addEventListener('change', function() {
      topicRatings[sel.id] = sel.value;
      saveData("topicRatings", topicRatings);
    });
  });

  // load progress log
  var progressLog = loadData("progressLog") || [];
  renderProgressLog(progressLog);

  // days left calculator (replace with actual exam date)
  document.getElementById('daysLeft').innerText = '21 (manual)';
}
</script>
</head>
<body>
<h1>🎯 JMI B04 Entrance Prep Tracker 2026</h1>
<div class="tab">
  <button class="tablinks active" onclick="openTab(event, 'Dashboard')">📊 Dashboard</button>
  <button class="tablinks" onclick="openTab(event, 'Plan')">📅 21-Day Plan</button>
  <button class="tablinks" onclick="openTab(event, 'Topics')">🧠 Topic Mastery</button>
  <button class="tablinks" onclick="openTab(event, 'Resources')">🔗 Resources</button>
  <button class="tablinks" onclick="openTab(event, 'Progress')">📈 Progress Log</button>
</div>

<!-- Dashboard Tab -->
<div id="Dashboard" class="tabcontent">
  <h3>Section Weights (Official Syllabus 2026-27)</h3>
  <table>
    <tr><th>Section</th><th>Marks</th><th>Questions</th></tr>
    <tr><td>Business & Economic Awareness</td><td>30</td><td>30</td></tr>
    <tr><td>Reasoning & Quantitative Aptitude</td><td>25</td><td>25</td></tr>
    <tr><td>General English</td><td>25</td><td>25</td></tr>
    <tr><td>General Awareness</td><td>20</td><td>20</td></tr>
  </table>
  <p><b>Target Score:</b> 60-75 / 100</p>
  <p><b>Days Left:</b> <span id="daysLeft">21</span> (adjust as per exam date)</p>
  <div class="progress-wrap">
    <div class="progress-bar" style="width:0%;" id="overallProgress">0%</div>
  </div>
  <p style="background:#fff3cd; padding:10px; border-radius:5px;">⚠️ Negative marking: -0.25 per wrong answer. Attempt only if ≥60% confident. Skip unsure ones.</p>
</div>

<!-- 21-Day Plan Tab -->
<div id="Plan" class="tabcontent">
  <h3>21-Day Study Plan (Mixed Subjects)</h3>
  <table id="planTable">
    <tr><th>Day</th><th>Section Focus</th><th>Topics to Cover</th><th>Resource</th><th>Done</th></tr>
    <tr><td>1</td><td>Business</td><td>Fayol 14 principles; POSDC</td><td>NCERT Ch 2; Rajat Arora playlist</td><td><input type="checkbox" id="d1"></td></tr>
    <tr><td>2</td><td>Business</td><td>Taylor's Scientific Mgmt; Coordination</td><td>NCERT Ch 2 + Rajat Arora</td><td><input type="checkbox" id="d2"></td></tr>
    <tr><td>3</td><td>Business</td><td>Staffing, Directing, Leadership, Grapevine</td><td>NCERT Ch 6-7</td><td><input type="checkbox" id="d3"></td></tr>
    <tr><td>4</td><td>Business</td><td>Marketing (4Ps, Branding, Consumer Protection)</td><td>NCERT Ch 11-12</td><td><input type="checkbox" id="d4"></td></tr>
    <tr><td>5</td><td>Economics</td><td>GDP, GNP, NNP, National Income concepts</td><td>NCERT Macro Ch 2</td><td><input type="checkbox" id="d5"></td></tr>
    <tr><td>6</td><td>Economics</td><td>Money & Banking (RBI tools, CRR, SLR)</td><td>NCERT Macro Ch 3</td><td><input type="checkbox" id="d6"></td></tr>
    <tr><td>7</td><td>Economics</td><td>Inflation, Unemployment, Stagflation, 1991 reforms</td><td>NCERT Macro Ch 4-5</td><td><input type="checkbox" id="d7"></td></tr>
    <tr><td>8</td><td>Accounts</td><td>Partnership basics, profit-sharing, goodwill</td><td>NCERT Accounts Part 1 Ch 1-2</td><td><input type="checkbox" id="d8"></td></tr>
    <tr><td>9</td><td>Accounts</td><td>Financial Ratios, Cash Flow Statement</td><td>NCERT Accounts Part 2 Ch 3-4</td><td><input type="checkbox" id="d9"></td></tr>
    <tr><td>10</td><td>Accounts</td><td>Share capital, Forfeiture, Primary/Secondary markets</td><td>NCERT Accounts + Ch 10</td><td><input type="checkbox" id="d10"></td></tr>
    <tr><td>11</td><td>Reasoning</td><td>Number Series (30 Qs)</td><td>IndiaBix.com</td><td><input type="checkbox" id="d11"></td></tr>
    <tr><td>12</td><td>Reasoning</td><td>Blood Relations, Directions (30 Qs each)</td><td>IndiaBix</td><td><input type="checkbox" id="d12"></td></tr>
    <tr><td>13</td><td>Reasoning</td><td>Coding-Decoding, Seating, Analogies (30 Qs)</td><td>IndiaBix + Testbook</td><td><input type="checkbox" id="d13"></td></tr>
    <tr><td>14</td><td>Quant</td><td>Percentages, Profit/Loss, Ratio, Average</td><td>IndiaBix + Career Ride</td><td><input type="checkbox" id="d14"></td></tr>
    <tr><td>15</td><td>Quant</td><td>Time & Work, Distance, Trains, Simple Interest, Probability</td><td>IndiaBix + Career Ride</td><td><input type="checkbox" id="d15"></td></tr>
    <tr><td>16</td><td>Quant/Stats</td><td>Mean, Median, Mode, Correlation, Frequency dist.</td><td>NCERT Class 11 Stats Ch 15-16</td><td><input type="checkbox" id="d16"></td></tr>
    <tr><td>17</td><td>English</td><td>Tenses, Prepositions, Subject-verb agreement (30 Qs)</td><td>EnglishGrammar101.com</td><td><input type="checkbox" id="d17"></td></tr>
    <tr><td>18</td><td>English</td><td>Synonyms, Antonyms, Error detection, RC strategy</td><td>WordPandit.com</td><td><input type="checkbox" id="d18"></td></tr>
    <tr><td>19</td><td>Computer</td><td>Hardware, Software, Networks, Protocols</td><td>GKToday Computer PDF</td><td><input type="checkbox" id="d19"></td></tr>
    <tr><td>20</td><td>GA</td><td>Current affairs Sep 2025 - Feb 2026</td><td>GKToday Monthly PDF</td><td><input type="checkbox" id="d20"></td></tr>
    <tr><td>21</td><td>REVISION</td><td>Full mock (2025 PYQ), review mistakes</td><td>Your PYQ files</td><td><input type="checkbox" id="d21"></td></tr>
  </table>
</div>

